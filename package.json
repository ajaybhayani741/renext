{
  "name": "mat-next",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@embedpdf/react-pdf-viewer": "^2.1.1",
    "@react-google-maps/api": "^2.20.5",
    "@reduxjs/toolkit": "^2.8.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "antd": "^5.26.2",
    "axios": "^1.10.0",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.13",
    "env-cmd": "^10.1.0",
    "firebase": "^10.14.1",
    "google-auth-library": "^9.15.1",
    "google-maps-react-markers": "^2.0.15",
    "google-spreadsheet": "^4.1.4",
    "highcharts": "^11.4.8",
    "highcharts-react-official": "^3.2.2",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "i18next-xhr-backend": "^3.2.2",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-redux": "^9.2.0",
    "react-resize-detector": "^10.0.1",
    "react-router-dom": "^6.30.1",
    "react-scripts": "5.0.1",
    "react-webcam": "^7.2.0",
    "recharts": "^2.15.4",
    "sass": "^1.89.2",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "prepare": "husky install",
    "lint": "eslint src --color",
    "lint:fix": "npx eslint --fix 'src/**/*.{js,jsx}'",
    "prettier": "prettier src --check",
    "format": "prettier --write \"{,!(node_modules)/**/}*.{js,jsx,css,eslintrc,prettierrc}\"",
    "husky-install": "husky install",
    "build:development": "env-cmd -f .env.development react-scripts build",
    "getlang": "cd src/i18n/ && node script.js"
  },
  "devDependencies": {
    "dotenv": "^16.5.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.5.2",
    "prettier": "3.6.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.js": "eslint --fix --max-warnings=0",
    "*.jsx": "eslint --fix --max-warnings=0"
  }
}
